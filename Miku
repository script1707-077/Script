local function applyAnimatedGradient(obj, colors)
    if not obj:IsA("TextLabel") and not obj:IsA("TextButton") and not obj:IsA("TextBox") and not obj:IsA("UIStroke") and not obj:IsA("Frame") then return end
    local grad = Instance.new("UIGradient")
    if type(colors) == "table" then grad.Color = ColorSequence.new(colors) else grad.Color = colors end
    grad.Rotation = 45
    grad.Parent = obj
    table.insert(activeGradients, grad)
    return grad
end

RunService.RenderStepped:Connect(function()
    for _, grad in ipairs(activeGradients) do
        if grad.Parent then grad.Rotation = (grad.Rotation + 2) % 360 end
    end
end)

local function destroyGarbage(item)
    if not item then return end
    if item:IsA("Accessory") or item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") or item:IsA("CharacterMesh") or item:IsA("Hat") or item:IsA("FaceControls") then
        item:Destroy()
    elseif item:IsA("Decal") and (item.Name == "face" or item.Parent.Name == "Head") then
        item:Destroy()
    end
end

local function globalSweep()
    if not state.antiLagEnabled then return end
    for _, descendant in ipairs(Workspace:GetDescendants()) do destroyGarbage(descendant) end
end

Workspace.DescendantAdded:Connect(function(descendant)
    if state.antiLagEnabled then destroyGarbage(descendant) end
end)

